#!/usr/bin/env sh
# pre-commit (husky v9)
# 1) lint-staged: 仅对 staged 源码跑 eslint --fix + prettier --write（不扫 _bmad-output/.claude/.md）
bunx lint-staged || exit 1

# 2) forbidden-files 守卫: gitignore 的主动补充层,挡 force-add / 已 tracked 的垃圾
#    grep -E 匹配 staged 新增文件;命中即拦截
deny() {
  if git diff --cached --name-only --diff-filter=A | grep -Eq "$1"; then
    echo "✗ 禁止提交的路径匹配: $1"
    echo "  git restore --staged <file> 后重试"
    exit 1
  fi
}
deny '^package-lock\.json$'      # npm lockfile(repo 用 bun.lock)
deny '^\.claude/'                # CC 工具链(skills/plans/settings 全部 dev-env)
deny '^[^/]+\.png$'              # 根级 PNG(sd-sim-*.png 等;IDEA/*.png 有 / 不匹配)
