#!/usr/bin/env sh
# pre-push (husky v9)
# 把本轮两个 CI blocker(lockfile drift + lint any)的同源问题挡在 push 前
# 注: vitest 留给 CI(~18s 太慢);本钩覆盖 lockfile + lint + 类型
echo "▶ pre-push: frozen-lockfile + lint + typecheck"

bun install --frozen-lockfile || {
  echo "✗ lockfile 与 package.json 不同步"
  echo "  本地跑 bun install 后提交 bun.lock 再 push"
  exit 1
}
bun run lint || { echo "✗ lint 失败"; exit 1; }
bun run typecheck || { echo "✗ typecheck 失败"; exit 1; }
echo "✓ pre-push 通过"
