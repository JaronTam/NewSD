# NewSD server env. main.go reads os.Getenv only - NO .env autoload.
# Load before starting Go server: `set -a; source .env; set +a; go run .`
#   (Windows pwsh: set $env:VAR per line, or use a launcher)
# NEVER commit real values. SDR#6: client_secret fields never leave server.

# --- Server ---
PORT=8080
# Bind address. Default 127.0.0.1 (dev localhost-only; avoids LAN exposure of
# dev server incl. FAKE_OAUTH). Prod behind reverse proxy: set 0.0.0.0.
BIND_ADDR=127.0.0.1
DB_PATH=data/newsd.db
# Session TTL as Go duration; empty -> code default (store.SessionTTL).
SESSION_TTL=

# --- OAuth (SDR#4 fail-fast: prod needs at least one provider fully configured) ---
# Redirect base without trailing slash; callback path appended by server.
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# GitHub OAuth App credentials. SECRET is server-only (SDR#6 hard red line).
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Google OAuth credentials. SECRET is server-only (SDR#6 hard red line).
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- Dev-only fake provider (Q2=B). Set =1 to skip real OAuth; UNSET in prod. ---
FAKE_OAUTH=
